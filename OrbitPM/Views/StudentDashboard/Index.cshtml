@model IEnumerable<OrbitPM.Models.ProposalOwnership>
@{
    ViewData["Title"] = "Student Dashboard - My Proposals";
}

<style>
    body {
        background: #f8fafc;
        font-family: 'Inter', system-ui, sans-serif;
    }
    
    .status-badge {
        padding: 0.5rem 1rem;
        border-radius: 50rem;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }
    .status-pending { background-color: #fef3c7; color: #d97706; border: 1px solid #fde68a; }
    .status-matched { background-color: #d1fae5; color: #059669; border: 1px solid #a7f3d0; }
    .status-withdrawn { background-color: #f1f5f9; color: #64748b; border: 1px solid #e2e8f0; }
    
    .project-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        border: 1px solid #e2e8f0;
        padding: 2rem;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .project-card:hover { box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.08); transform: translateY(-3px); }

    .reveal-box {
        background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
        color: white;
        border-radius: 8px;
        padding: 1.5rem;
        margin-top: 1.5rem;
        position: relative;
        overflow: hidden;
        border: 1px solid #4338ca;
    }
    .reveal-box::before {
        content: '\F210'; /* Bootstrap icon lock-fill mapped visually */
        font-family: "bootstrap-icons";
        position: absolute;
        right: -20px;
        top: -20px;
        font-size: 8rem;
        opacity: 0.05;
        transform: rotate(15deg);
    }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="fw-bold mb-1"><i class="bi bi-mortarboard-fill text-primary me-2"></i>My Projects</h1>
            <p class="text-muted mb-0">Track your submitted project proposals or create a new one.</p>
        </div>
        <div>
            <a asp-action="CreateProposal" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> New Proposal
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 border rounded bg-white shadow-sm">
            <i class="bi bi-folder-x text-muted" style="font-size: 3rem;"></i>
            <h4 class="mt-3 text-secondary">You haven't submitted any projects yet.</h4>
            <p class="text-muted">Create a proposal to have it anonymously reviewed by supervisors.</p>
            <a asp-action="CreateProposal" class="btn btn-outline-primary mt-3">Submit your first idea</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var ownership in Model)
            {
                var proposal = ownership.ProjectProposal!;
                <div class="col-lg-6">
                    <div class="project-card d-flex flex-column h-100">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-muted small fw-bold">#@proposal.Id.ToString("D4")</span>
                            <span class="status-badge @(proposal.Status == OrbitPM.Models.ProjectStatus.Pending ? "status-pending" : proposal.Status == OrbitPM.Models.ProjectStatus.Matched ? "status-matched" : "status-withdrawn")">
                                <i class="bi @(proposal.Status == OrbitPM.Models.ProjectStatus.Pending ? "bi-hourglass-split" : proposal.Status == OrbitPM.Models.ProjectStatus.Matched ? "bi-check-circle" : "bi-x-circle") me-1"></i>
                                @proposal.Status.ToString()
                            </span>
                        </div>
                        
                        <h4 class="fw-bold mb-2">@proposal.Title</h4>
                        <div class="mb-3 text-muted small">
                            <strong>Area:</strong> @(proposal.ResearchArea?.Name ?? "Uncategorized")  •  
                            <strong>Submitted:</strong> @ownership.SubmittedAt.ToString("MMM dd, yyyy")
                        </div>
                        
                        <p class="text-secondary flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @proposal.Abstract
                        </p>

                        @if (proposal.Status == OrbitPM.Models.ProjectStatus.Pending)
                        {
                            <div class="mt-4 pt-3 border-top text-end">
                                <a asp-action="EditProposal" asp-route-id="@proposal.Id" class="btn btn-outline-primary btn-sm me-2 fw-bold">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form asp-action="WithdrawProposal" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to withdraw this proposal?');">
                                    <input type="hidden" name="proposalId" value="@proposal.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm fw-bold">
                                        <i class="bi bi-trash"></i> Withdraw
                                    </button>
                                </form>
                            </div>
                        }
                        
                        @if (proposal.Status == OrbitPM.Models.ProjectStatus.Matched && proposal.MatchRecord != null)
                        {
                            <div class="reveal-box mt-auto">
                                <h6 class="text-info fw-bold mb-2 text-uppercase" style="letter-spacing: 1px; font-size: 0.75rem;"><i class="bi bi-unlock-fill me-1"></i> Identity Revealed</h6>
                                <div class="opacity-75 small mb-1">Supervisor Matched:</div>
                                <h5 class="fw-bold mb-0">@(proposal.MatchRecord.Supervisor?.FullName ?? "Dr. Assigned Supervisor")</h5>
                                <div class="mt-2 pt-2 border-top border-secondary small">
                                    <i class="bi bi-envelope me-1"></i> supervisor@university.edu
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

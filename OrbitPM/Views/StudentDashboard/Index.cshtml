@model IEnumerable<OrbitPM.Models.ProposalOwnership>
@{
    ViewData["Title"] = "Student Dashboard - My Proposals";
}

<div class="container py-4">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-5 fade-in-up">
        <div>
            <h1 class="fw-800 display-5 mb-1 text-white">
                <i class="bi bi-mortarboard-fill text-primary me-3"></i>My Projects
            </h1>
            <p class="text-dim mb-0 lead-sm">Track your progress and manage your research proposals.</p>
        </div>
        <div>
            <a asp-action="CreateProposal" class="btn btn-primary d-flex align-items-center gap-2">
                <i class="bi bi-plus-circle-fill fs-5"></i>
                <span>New Proposal</span>
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert glass-alert border-primary border-opacity-25 d-flex align-items-center mb-4 fade-in-up" role="alert">
            <i class="bi bi-check-circle-fill text-primary me-3 fs-4"></i>
            <div class="text-white">@TempData["SuccessMessage"]</div>
            <button type="button" class="ms-auto btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card p-5 text-center border-dashed fade-in-up" style="border: 2px dashed var(--glass-border) !important; background: transparent !important;">
            <div class="mb-4">
                <div class="d-inline-flex p-4 rounded-circle bg-surface-light mb-3">
                    <i class="bi bi-rocket-takeoff text-dim" style="font-size: 3.5rem;"></i>
                </div>
            </div>
            <h3 class="fw-bold text-white mb-2">No projects started yet</h3>
            <p class="text-dim mb-4 mx-auto" style="max-width: 400px;">Begin your research journey by submitting your first proposal. Our supervisors are waiting to review your ideas.</p>
            <a asp-action="CreateProposal" class="btn btn-outline-light px-4">
                Launch Initial Proposal
            </a>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var ownership in Model)
            {
                var proposal = ownership.ProjectProposal!;
                <div class="col-lg-6">
                    <div class="card h-100 fade-in-up shadow-lg">
                        <div class="card-body p-4 d-flex flex-column">
                            <!-- Card Header -->
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div class="d-flex flex-column">
                                    <span class="text-primary fw-800 small text-uppercase tracking-wider mb-1">Project ID</span>
                                    <span class="font-monospace text-white">#@proposal.Id.ToString("D4")</span>
                                </div>
                                <div class="badge-group">
                                    @{
                                        var statusClass = proposal.Status switch {
                                            OrbitPM.Models.ProjectStatus.Pending => "bg-warning",
                                            OrbitPM.Models.ProjectStatus.Matched => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                        var statusIcon = proposal.Status switch {
                                            OrbitPM.Models.ProjectStatus.Pending => "bi-hourglass-split",
                                            OrbitPM.Models.ProjectStatus.Matched => "bi-shield-check",
                                            _ => "bi-slash-circle"
                                        };
                                    }
                                    <span class="badge @statusClass bg-opacity-10 text-@statusClass.Replace("bg-", "") border border-@statusClass.Replace("bg-", "") border-opacity-25 py-2 px-3">
                                        <i class="bi @statusIcon me-2"></i>@proposal.Status
                                    </span>
                                </div>
                            </div>
                            
                            <!-- Content -->
                            <h3 class="fw-bold text-white mb-3">@proposal.Title</h3>
                            
                            <div class="d-flex flex-wrap gap-3 mb-4">
                                <div class="d-flex align-items-center text-dim small">
                                    <i class="bi bi-tag-fill text-primary me-2"></i>
                                    <span>@(proposal.ResearchArea?.Name ?? "Uncategorized")</span>
                                </div>
                                <div class="d-flex align-items-center text-dim small">
                                    <i class="bi bi-calendar3 text-primary me-2"></i>
                                    <span>@ownership.SubmittedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                            
                            <p class="text-dim mb-4 line-clamp-2">
                                @proposal.Abstract
                            </p>

                            <!-- Actions / Reveal Container -->
                            <div class="mt-auto">
                                @if (proposal.Status == OrbitPM.Models.ProjectStatus.Pending)
                                {
                                    <div class="pt-4 border-top border-white border-opacity-10 d-flex justify-content-end gap-2">
                                        <a asp-action="EditProposal" asp-route-id="@proposal.Id" class="btn btn-outline-light btn-sm px-3">
                                            <i class="bi bi-pencil-square me-1"></i> Edit
                                        </a>
                                        <form asp-action="WithdrawProposal" method="post" class="d-inline">
                                            <input type="hidden" name="proposalId" value="@proposal.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm px-3" onclick="return confirm('Withdraw proposal #@proposal.Id?')">
                                                <i class="bi bi-trash-fill me-1"></i> Withdraw
                                            </button>
                                        </form>
                                    </div>
                                }
                                
                                @if (proposal.Status == OrbitPM.Models.ProjectStatus.Matched && proposal.MatchRecord != null)
                                {
                                    <div class="card bg-surface-light border-0 shadow-sm mt-4 overflow-hidden">
                                        <div class="card-body p-3">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold rounded-3" style="width: 50px; height: 50px; font-size: 1.2rem;">
                                                    <i class="bi bi-person-check-fill"></i>
                                                </div>
                                                <div class="flex-grow-1">
                                                    <div class="text-white fw-bold mb-0">@(proposal.MatchRecord.Supervisor?.FullName ?? "Assigned Supervisor")</div>
                                                    <div class="text-dim small">Matched Supervisor</div>
                                                </div>
                                                <div>
                                                    <a href="mailto:supervisor@university.edu" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                                        <i class="bi bi-envelope me-1"></i> Contact
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .fw-800 { font-weight: 800; }
    .text-dim { color: var(--text-dim) !important; }
    .lead-sm { font-size: 1.1rem; opacity: 0.8; }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .tracking-wider { letter-spacing: 0.05em; }
    .tracking-widest { letter-spacing: 0.15em; }
    .extra-small { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }

    .glass-alert {
        background: rgba(0, 242, 254, 0.05);
        backdrop-filter: blur(10px);
        border-radius: 16px;
    }

    .card {
        transition: var(--transition-smooth);
    }
</style>

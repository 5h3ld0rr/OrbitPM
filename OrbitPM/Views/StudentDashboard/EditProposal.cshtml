@model OrbitPM.Models.ProjectProposal
@{
    ViewData["Title"] = "Update Proposal Details";
}

<div class="row justify-content-center mt-5 fade-in-up">
    <div class="col-md-8">
        <div class="card border-0 rounded-5 shadow-lg p-5" style="background: linear-gradient(180deg, rgba(13,20,36,0.8) 0%, rgba(5,8,16,0.95) 100%); backdrop-filter: blur(30px); border: 1px solid rgba(255,255,255,0.05) !important;">
            <div class="d-flex align-items-center mb-4">
                <div class="feature-icon-wrapper me-3 pulse-glow" style="width: 50px; height: 50px;">
                    <i class="bi bi-pencil-square"></i>
                </div>
                <div>
                    <h2 class="fw-bolder text-white mb-0">Modify Proposal</h2>
                    <p class="text-secondary mb-0">Update your abstract or tech stack securely</p>
                </div>
            </div>
            
            <form asp-action="EditProposal" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="form-floating mb-4">
                    <input asp-for="Title" class="form-control bg-transparent text-white border-secondary" placeholder="Project Title" required />
                    <label asp-for="Title" class="text-secondary">Project Title</label>
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-4">
                    <select asp-for="ResearchAreaId" class="form-select bg-dark text-white border-secondary" asp-items="ViewBag.ResearchAreas" required>
                        <option value="">-- Select Domain --</option>
                    </select>
                    <label asp-for="ResearchAreaId" class="text-secondary">Research Domain</label>
                    <span asp-validation-for="ResearchAreaId" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-4">
                    <textarea asp-for="Abstract" class="form-control bg-transparent text-white border-secondary" style="height: 150px" placeholder="Abstract" required></textarea>
                    <label asp-for="Abstract" class="text-secondary">Project Abstract / Summary</label>
                    <span asp-validation-for="Abstract" class="text-danger small"></span>
                </div>
                
                <div class="form-floating mb-4">
                    <input asp-for="TechnicalStack" class="form-control bg-transparent text-white border-secondary" placeholder="e.g. React, Node, SQL" />
                    <label asp-for="TechnicalStack" class="text-secondary">Technical Stack (Comma separated)</label>
                    <span asp-validation-for="TechnicalStack" class="text-danger small"></span>
                </div>
                
                <div class="d-flex justify-content-end gap-3 mt-5">
                    <a asp-action="Index" class="btn btn-outline-light rounded-pill px-4 fw-bold text-secondary border-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">Update Signal <i class="bi bi-arrow-up-circle ms-2"></i></button>
                </div>
            </form>
        </div>
    </div>
</div>

@model IEnumerable<OrbitPM.Models.ResearchArea>
@{
    ViewData["Title"] = "Configure Domains";
}

<div class="row justify-content-center mt-5 fade-in-up">
    <div class="col-md-10 mb-3">
        <a asp-action="Index" class="text-dim text-decoration-none extra-small fw-800 text-uppercase tracking-widest hover-main transition-all">
            <i class="bi bi-chevron-left me-2"></i>Return to Dashboard
        </a>
    </div>
    <div class="col-md-10">
        <!-- Main Registry Card -->
        <div class="card border border-info border-opacity-25 shadow-2xl rounded-4 overflow-hidden" 
             style="background: linear-gradient(135deg, rgba(15, 23, 42, 0.6) 0%, rgba(2, 6, 23, 0.8) 100%); backdrop-filter: blur(10px);">
            
            <!-- Deep Midnight Header -->
            <div class="p-4 d-flex align-items-center border-bottom border-info border-opacity-30" style="background: #020617;">
                <div class="bg-primary p-2 rounded-3 me-3 d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                    <i class="bi bi-grid-3x3-gap-fill text-white fs-4"></i>
                </div>
                <h4 class="fw-800 mb-0 tracking-tight text-white">Domain Registry</h4>
            </div>

            <div class="p-4 p-md-5">
                <!-- Action Row -->
                <div class="d-flex justify-content-between align-items-end mb-5">
                    <div class="flex-grow-1 me-4">
                        <form asp-action="CreateResearchArea" method="post">
                            <label class="form-label extra-small fw-800 text-dim tracking-widest mb-3">PROVISION NEW DOMAIN</label>
                            <div class="input-group input-group-lg shadow-sm rounded-4 overflow-hidden">
                                <input type="text" name="name" 
                                       class="form-control border-0 text-white" 
                                       style="font-size: 0.95rem; background: var(--input-bg); border-top-right-radius: 0 !important; border-bottom-right-radius: 0 !important;"
                                       placeholder="Enter research field identity..." required />
                                <button type="submit" class="btn btn-primary px-4 fw-800 text-uppercase small">
                                    ADD <i class="bi bi-plus-lg ms-2"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="glass-alert border-0 p-3 mb-4 scale-in">
                        <i class="bi bi-check-circle-fill text-success me-2"></i> @TempData["SuccessMessage"]
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="glass-alert border-0 p-3 mb-4 scale-in" style="background: rgba(220, 53, 69, 0.1);">
                        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i> @TempData["ErrorMessage"]
                    </div>
                }

                <!-- Draggable Allocation Table -->
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 interstate-table">
                        <thead>
                            <tr>
                                <th class="ps-4">DOMAIN IDENTITY</th>
                                <th class="text-end pe-4">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody id="sortable-domains">
                            @foreach(var area in Model.OrderBy(a => a.DisplayOrder))
                            {
                                <tr data-id="@area.Id" class="draggable-row cursor-grab">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-info bg-opacity-20 p-2 rounded-3 me-3 border border-info border-opacity-30 shadow-sm" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                                <i class="bi bi-tag text-white fs-5"></i>
                                            </div>
                                            <span class="fw-800 fs-5" style="color: var(--text-main);">@area.Name.ToLower()</span>
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-3 px-2">
                                            <button class="btn-action edit" data-bs-toggle="modal" data-bs-target="#editModal-@area.Id">
                                                <i class="bi bi-pencil-square me-1"></i>RENAME
                                            </button>
                                            
                                            <form asp-action="DeleteResearchArea" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@area.Id" />
                                                <button type="submit" class="btn-action revoke" onclick="return confirm('Permanently remove domain: @area.Name?')">
                                                    <i class="bi bi-x-circle me-1"></i>REMOVE
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
            <div class="p-4 border-top border-info border-opacity-20 d-flex justify-content-between align-items-center" style="background: #020617;">
                <span class="extra-small text-dim fw-800 text-uppercase tracking-widest">Global Domain Registry Summary</span>
                <span id="save-status" class="extra-small text-info fw-800 text-uppercase tracking-widest d-none">
                    <i class="bi bi-cloud-upload-fill me-2 rotate-gear"></i>Syncing Sequence...
                </span>
                <span class="active-badge">
                    TOTAL REGISTERED: @Model.Count() ENTITIES
                </span>
            </div>
        </div>
    </div>
</div>


<style>
    .interstate-table thead th {
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--text-dim);
        letter-spacing: 0.1rem;
        border-bottom: 2px solid rgba(0, 242, 255, 0.2);
        padding-bottom: 1.25rem;
        text-transform: uppercase;
    }
    
    .interstate-table tbody tr {
        border-bottom: 1px solid rgba(0, 242, 255, 0.1);
        transition: background 0.2s ease;
    }
    
    .interstate-table tbody tr:hover {
        background: rgba(0, 242, 255, 0.04) !important;
    }
    
    .interstate-table td {
        padding: 1.25rem 0.5rem;
    }

    .btn-action {
        background: transparent;
        border: none;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.05rem;
        display: flex;
        align-items: center;
        padding: 0;
        transition: opacity 0.2s;
        text-transform: uppercase;
        position: relative;
        z-index: 10;
        pointer-events: auto;
    }
    
    .btn-action.revoke { color: #ff3344; }
    .btn-action.edit { color: var(--text-dim); }
    .btn-action:hover { opacity: 0.7; }

    .cursor-grab { cursor: grab; }
    .cursor-grab:active { cursor: grabbing; }

    .sortable-ghost {
        opacity: 0.4;
        background: rgba(var(--bs-primary-rgb), 0.1) !important;
    }

    .active-badge {
        background: #00f2ff;
        color: #020617;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.05rem;
        padding: 4px 16px;
        border-radius: 50px;
        display: inline-block;
        box-shadow: 0 0 15px rgba(0, 242, 255, 0.4);
        text-transform: uppercase;
    }

    .tracking-tight { letter-spacing: -0.025em; }
    .extra-small { font-size: 0.65rem; }
    .shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); }
    .tracking-widest { letter-spacing: 0.2em; }
    
    .hover-light:hover { color: white !important; }
    .transition-all { transition: all 0.2s ease; }

    .rotate-gear {
        display: inline-block;
        animation: spin 2s linear infinite;
    }
    @@keyframes spin { 100% { transform: rotate(360deg); } }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const el = document.getElementById('sortable-domains');
            const saveStatus = document.getElementById('save-status');
            
            new Sortable(el, {
                animation: 250,
                ghostClass: 'sortable-ghost',
                filter: '.btn-action, .modal, .modal-dialog, .modal-content, input, button',
                preventOnFilter: false, 
                onEnd: function() {
                    const sortedIds = Array.from(el.querySelectorAll('tr')).map(tr => parseInt(tr.dataset.id));
                    
                    saveStatus.classList.remove('d-none');
                    
                    fetch('@Url.Action("UpdateDomainOrder")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: JSON.stringify(sortedIds)
                    })
                    .then(response => {
                        if (response.ok) {
                            setTimeout(() => saveStatus.classList.add('d-none'), 1000);
                        }
                    })
                    .catch(error => {
                        console.error('Error saving order:', error);
                        saveStatus.innerHTML = '<i class="bi bi-exclamation-circle-fill text-danger me-2"></i>Sync Failed';
                    });
                }
            });
        });
    </script>
}

<!-- Modals Container - Root Level -->
@foreach(var area in Model)
{
    <div class="modal fade" id="editModal-@area.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-black border border-info border-opacity-20 shadow-2xl rounded-4">
                <div class="modal-header border-bottom border-info border-opacity-20 p-4" style="background: #020617;">
                    <h5 class="modal-title fw-800 text-white">Modify Domain Identity</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="EditResearchArea" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body p-4 text-start">
                        <input type="hidden" name="id" value="@area.Id" />
                        <label class="form-label extra-small fw-800 text-dim mb-3">CURRENT DESIGNATION</label>
                        <input type="text" name="name" value="@area.Name" 
                               class="form-control text-white py-3" 
                               required 
                               style="background: var(--input-bg); outline: none !important; box-shadow: none !important;" />
                    </div>
                    <div class="modal-footer border-top border-info border-opacity-20 p-4">
                        <button type="submit" class="btn btn-primary px-4 rounded-pill fw-800 text-uppercase small shadow-lg">Update Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@model IEnumerable<OrbitPM.Models.ApplicationUser>
@{
    ViewData["Title"] = "Configure Users";
}

<div class="row justify-content-center mt-5 fade-in-up">
    <div class="col-md-10 mb-3">
        <a asp-action="Index" class="text-dim text-decoration-none extra-small fw-800 text-uppercase tracking-widest hover-main transition-all">
            <i class="bi bi-chevron-left me-2"></i>Return to Dashboard
        </a>
    </div>
    <div class="col-md-10">
        <!-- Main Registry Card -->
        <div class="card border border-info border-opacity-25 shadow-2xl rounded-4 overflow-hidden" 
             style="background: linear-gradient(135deg, rgba(15, 23, 42, 0.6) 0%, rgba(2, 6, 23, 0.8) 100%); backdrop-filter: blur(10px);">
            
            <!-- Deep Midnight Header -->
            <div class="p-4 d-flex align-items-center border-bottom border-info border-opacity-30" style="background: #020617;">
                <div class="bg-primary p-2 rounded-3 me-3 d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                    <i class="bi bi-people-fill text-white fs-4"></i>
                </div>
                <h4 class="fw-800 text-white mb-0 tracking-tight">Member Registry</h4>
                
                <div class="ms-auto">
                    <button class="btn btn-primary btn-sm rounded-pill px-4 fw-800 text-uppercase small" data-bs-toggle="collapse" data-bs-target="#createUserForm">
                        <i class="bi bi-plus-lg me-1"></i> Provision Member
                    </button>
                </div>
            </div>

            <div class="p-4 p-md-5">
                <!-- Expandable Creation Form -->
                <div class="collapse mb-5" id="createUserForm">
                    <div class="card bg-white bg-opacity-5 border border-info border-opacity-20 rounded-4 p-4 shadow-lg">
                        <h6 class="text-white fw-800 text-uppercase extra-small tracking-widest mb-4">Initialize Account Entity</h6>
                        <form asp-action="CreateUser" method="post">
                            <div class="row g-4">
                                <div class="col-md-3">
                                    <label class="text-dim extra-small fw-800 tracking-wider mb-2">FULL NAME</label>
                                    <input type="text" name="fullName" class="form-control border-0 bg-black bg-opacity-30 text-white py-2" style="font-size: 0.9rem;" placeholder="Jane Doe" required />
                                </div>
                                <div class="col-md-3">
                                    <label class="text-dim extra-small fw-800 tracking-wider mb-2">EMAIL ADDRESS</label>
                                    <input type="email" name="email" class="form-control border-0 bg-black bg-opacity-30 text-white py-2" style="font-size: 0.9rem;" placeholder="jane@example.com" required />
                                </div>
                                <div class="col-md-3">
                                    <label class="text-dim extra-small fw-800 tracking-wider mb-2">MEMBER ROLE</label>
                                    <select name="role" class="form-select border-0 bg-black bg-opacity-30 text-white py-2" style="font-size: 0.9rem;" required>
                                        <option value="Student">Student</option>
                                        <option value="Supervisor">Supervisor</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="text-dim extra-small fw-800 tracking-wider mb-2">PASSWORD</label>
                                    <input type="password" name="rawPassword" class="form-control border-0 bg-black bg-opacity-30 text-white py-2" style="font-size: 0.9rem;" placeholder="••••••••" required />
                                </div>
                                <div class="col-12 text-end mt-4">
                                    <button type="submit" class="btn btn-primary px-5 fw-800 text-uppercase small rounded-pill">
                                        Confirm Access Provision
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="glass-alert border-0 p-3 mb-4 scale-in">
                        <i class="bi bi-check-circle-fill text-success me-2"></i> @TempData["SuccessMessage"]
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="glass-alert border-0 p-3 mb-4 scale-in" style="background: rgba(220, 53, 69, 0.1);">
                        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i> @TempData["ErrorMessage"]
                    </div>
                }

                <!-- Allocation Table Inspired Registry -->
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 interstate-table">
                        <thead>
                            <tr>
                                <th class="ps-0">MEMBER ENTITY</th>
                                <th class="text-center">ROLE IDENTITY</th>
                                <th class="text-end">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var user in Model)
                            {
                                <tr>
                                    <td class="ps-0">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm bg-primary bg-opacity-10 text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 38px; height: 38px;">
                                                <span class="fw-800 text-uppercase">@user.FullName?[0]</span>
                                            </div>
                                            <div>
                                                <div class="text-white fw-bold" style="font-size: 0.95rem;">@user.FullName?.ToLower()</div>
                                                <div class="text-dim extra-small text-uppercase tracking-wider" style="font-size: 0.65rem;">@user.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var roleColor = user.Role switch {
                                                "Student" => "primary",
                                                "Supervisor" => "success",
                                                "ModuleLeader" => "warning",
                                                _ => "secondary"
                                            };
                                        }
                                        <div class="d-flex align-items-center justify-content-center">
                                            <div class="status-dot-inner bg-@roleColor me-2"></div>
                                            <span class="extra-small fw-800 text-@roleColor text-uppercase">@user.Role</span>
                                        </div>
                                    </td>
                                    <td class="text-end pe-0">
                                        <div class="d-flex justify-content-end gap-3 px-2">
                                            @if(user.Id != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                            {
                                                <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Remove @user.FullName from the system?');" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit" class="btn-action revoke">
                                                        <i class="bi bi-x-circle me-1"></i>REMOVE
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="active-badge">ACTIVE ACCOUNT</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
            <div class="p-4 border-top border-info border-opacity-20 d-flex justify-content-between align-items-center" style="background: #020617;">
                <span class="extra-small text-dim fw-800 text-uppercase tracking-widest">Global Member Registry Summary</span>
                <span class="active-badge">
                    TOTAL SYSTEMS LOAD: @Model.Count() ENTITIES
                </span>
            </div>
        </div>
    </div>
</div>

<style>
    .interstate-table thead th {
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--text-dim);
        letter-spacing: 0.1rem;
        border-bottom: 2px solid rgba(0, 242, 255, 0.2);
        padding-bottom: 1.25rem;
        text-transform: uppercase;
    }
    
    .interstate-table tbody tr {
        border-bottom: 1px solid rgba(0, 242, 255, 0.1);
        transition: background 0.2s ease;
    }
    
    .interstate-table tbody tr:hover {
        background: rgba(255,255,255,0.02);
    }
    
    .interstate-table td {
        padding: 1.25rem 0.5rem;
    }

    .btn-action {
        background: transparent;
        border: none;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.05rem;
        display: flex;
        align-items: center;
        padding: 0;
        transition: opacity 0.2s;
        text-transform: uppercase;
    }
    
    .btn-action.revoke { color: #ff3344; }
    .btn-action.edit { color: var(--text-dim); }
    .btn-action:hover { opacity: 0.7; }

    .status-dot-inner {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        box-shadow: 0 0 8px currentColor;
    }

    .active-badge {
        background: #00f2ff;
        color: #020617;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 0.05rem;
        padding: 4px 16px;
        border-radius: 50px;
        display: inline-block;
        box-shadow: 0 0 15px rgba(0, 242, 255, 0.4);
        text-transform: uppercase;
    }

    .tracking-tight { letter-spacing: -0.025em; }
    .extra-small { font-size: 0.65rem; }
    .shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); }
    .tracking-widest { letter-spacing: 0.2em; }
    
    .hover-light:hover { color: white !important; }
    .transition-all { transition: all 0.2s ease; }
</style>

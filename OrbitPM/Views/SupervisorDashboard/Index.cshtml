@model IEnumerable<OrbitPM.Models.ProjectProposal>
@{
    ViewData["Title"] = "Supervisor Dashboard - Blind Match";
}

<div class="container py-4">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-5 fade-in-up">
        <div>
            <h1 class="fw-800 display-5 mb-1 text-white">
                <i class="bi bi-shield-lock-fill text-primary me-3"></i>Blind Review
            </h1>
            <p class="text-dim mb-0 lead-sm">Securely evaluate anonymous student proposals and confirm your interest.</p>
        </div>
        <div>
            <a asp-action="ManageExpertise" class="btn btn-outline-light d-flex align-items-center gap-2">
                <i class="bi bi-sliders fs-5"></i>
                <span>Manage Expertise</span>
            </a>
        </div>
    </div>

    <!-- Statistics Panel -->
    <div class="row g-4 mb-5">
        <div class="col-md-3 col-6">
            <div class="stat-card p-4 h-100 fade-in-up" style="animation-delay: 0.05s;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-3">
                        <i class="bi bi-stack text-primary fs-4"></i>
                    </div>
                    <span class="text-dim extra-small fw-800 tracking-widest text-uppercase">Direct Pool</span>
                </div>
                <h2 class="fw-800 mb-1">@ViewBag.Stats_TotalPool</h2>
                <div class="extra-small text-dim">Active Proposals</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card p-4 h-100 fade-in-up" style="animation-delay: 0.1s;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-info bg-opacity-10 p-2 rounded-3">
                        <i class="bi bi-geo-fill text-info fs-4"></i>
                    </div>
                    <span class="text-dim extra-small fw-800 tracking-widest text-uppercase">Map Match</span>
                </div>
                <h2 class="fw-800 mb-1">@ViewBag.Stats_ExpertiseMatch</h2>
                <div class="extra-small text-dim">Expertise Compatible</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card p-4 h-100 fade-in-up" style="animation-delay: 0.15s;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-warning bg-opacity-10 p-2 rounded-3">
                        <i class="bi bi-lightning-charge-fill text-warning fs-4"></i>
                    </div>
                    <span class="text-dim extra-small fw-800 tracking-widest text-uppercase">Interests</span>
                </div>
                <h2 class="fw-800 mb-1">@ViewBag.Stats_MyMatches</h2>
                <div class="extra-small text-dim">Expressed Interests</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card p-4 h-100 fade-in-up" style="animation-delay: 0.2s;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-success bg-opacity-10 p-2 rounded-3">
                        <i class="bi bi-shield-check text-success fs-4"></i>
                    </div>
                    <span class="text-dim extra-small fw-800 tracking-widest text-uppercase">Allocated</span>
                </div>
                <h2 class="fw-800 mb-1">@ViewBag.Stats_Approved</h2>
                <div class="extra-small text-dim">Approved Projects</div>
            </div>
        </div>
    </div>

    @if (ViewBag.MatchCount > 0)
    {
        <div class="match-reveal-module mb-5 fade-in-up">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-4">
                <div class="d-flex align-items-center">
                    <div class="supervisor-avatar me-4">
                        <i class="bi bi-lightning-charge-fill"></i>
                    </div>
                    <div>
                        <div class="match-reveal-tag">
                            <i class="bi bi-stars"></i> Priority Match Discovery
                        </div>
                        <h4 class="fw-bold text-white mb-1">High-Context Suggestions Available</h4>
                        <p class="text-dim mb-0">We found @ViewBag.MatchCount proposals strictly matching your academic research expertise.</p>
                    </div>
                </div>
                <button class="btn btn-primary px-4 fw-800" onclick="scrollToFirstMatch()">Focus Matches</button>
            </div>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert glass-alert border-primary border-opacity-25 d-flex align-items-center mb-4 fade-in-up" role="alert">
            <i class="bi bi-check-circle-fill text-primary me-3 fs-4"></i>
            <div class="text-white">@TempData["SuccessMessage"]</div>
            <button type="button" class="ms-auto btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card p-5 text-center border-dashed fade-in-up" style="border: 2px dashed var(--glass-border) !important; background: transparent !important;">
            <div class="mb-4">
                <div class="d-inline-flex p-4 rounded-circle bg-surface-light mb-3">
                    <i class="bi bi-rocket-takeoff-fill text-dim" style="font-size: 3.5rem;"></i>
                </div>
            </div>
            <h3 class="fw-bold text-white mb-2">No active proposals found</h3>
            <p class="text-dim mb-5 mx-auto" style="max-width: 500px;">The innovation pipeline is currently recharging. Optimize your research profile to ensure you never miss a perfect match.</p>
            
            <div class="row g-4 justify-content-center mb-5">
                <div class="col-md-4">
                    <div class="card bg-surface-light border-0 p-4 h-100">
                        <i class="bi bi-tags-fill text-primary fs-3 mb-3"></i>
                        <h6 class="fw-bold text-white">Academic Tags</h6>
                        <p class="extra-small text-dim mb-0">Define your expertise to trigger match alerts.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-surface-light border-0 p-4 h-100">
                        <i class="bi bi-incognito text-warning fs-3 mb-3"></i>
                        <h6 class="fw-bold text-white">Blind Eval</h6>
                        <p class="extra-small text-dim mb-0">Review based on merit, not identity metadata.</p>
                    </div>
                </div>
            </div>

            <a asp-action="ManageExpertise" class="btn btn-outline-light px-4">
                Update Security Profile
            </a>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var proposal in Model)
            {
                var isMatch = (ViewBag.MyAreaIds as List<int>)?.Contains(proposal.ResearchAreaId) ?? false;
                <div class="col-lg-6 @(isMatch ? "priority-match-item" : "")">
                    <div class="card h-100 fade-in-up shadow-lg @(isMatch ? "border-primary border-opacity-50" : "")">
                        <div class="card-body p-4 d-flex flex-column">
                            <!-- Card Header -->
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <div class="d-flex flex-column gap-1">
                                    <span class="badge border border-primary border-opacity-25 text-primary bg-primary bg-opacity-10 py-1 px-3 rounded-pill extra-small fw-800">
                                        @(proposal.ResearchArea?.Name ?? "General Research")
                                    </span>
                                    @if (isMatch)
                                    {
                                        <div class="text-warning extra-small fw-800 tracking-widest mt-1">
                                            <i class="bi bi-stars me-1"></i> PRIORITY MATCH
                                        </div>
                                    }
                                </div>
                                <span class="font-monospace text-dim small">#@proposal.Id.ToString("D4")</span>
                            </div>
                            
                            <!-- Content -->
                            <h4 class="fw-bold text-white mb-3 tracking-tight">@proposal.Title</h4>
                            
                            <p class="text-dim mb-4 line-clamp-3">
                                @proposal.Abstract
                            </p>

                            <div class="d-flex flex-wrap gap-2 mb-4 mt-auto">
                                @foreach(var tech in proposal.TechnicalStack.Split(new[] {','}, StringSplitOptions.RemoveEmptyEntries))
                                {
                                    <span class="badge bg-surface-light text-dim border border-white border-opacity-5 fw-500">@tech.Trim()</span>
                                }
                            </div>

                            <!-- Actions -->
                            <div class="pt-4 border-top border-white border-opacity-10 d-flex justify-content-between align-items-center">
                                <div class="extra-small text-dim d-flex align-items-center">
                                    <i class="bi bi-shield-check me-2 text-primary"></i> Blind Verified
                                </div>
                                <form asp-action="ExpressInterest" method="post" class="m-0">
                                    <input type="hidden" name="proposalId" value="@proposal.Id" />
                                    <button type="submit" class="btn btn-primary btn-sm px-4">
                                        Confirm Match
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function scrollToFirstMatch() {
            const firstMatch = document.querySelector('.priority-match-item');
            if (firstMatch) {
                firstMatch.scrollIntoView({ behavior: 'smooth', block: 'center' });
                firstMatch.querySelector('.card').style.borderColor = 'var(--primary)';
                firstMatch.querySelector('.card').style.boxShadow = '0 0 30px rgba(0, 242, 254, 0.2)';
            }
        }
    </script>
}

<style>
    .fw-800 { font-weight: 800; }
    .text-dim { color: var(--text-dim) !important; }
    .lead-sm { font-size: 1.1rem; opacity: 0.8; }
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .tracking-widest { letter-spacing: 0.15em; }
    .tracking-tight { letter-spacing: -0.025em; }
    .extra-small { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }
    .fw-500 { font-weight: 500; }
</style>


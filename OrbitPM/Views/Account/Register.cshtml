@model OrbitPM.Models.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card p-4 p-md-5">
            <div class="text-center mb-5">
                <div class="p-3 bg-primary bg-opacity-10 rounded-4 d-inline-block mb-4">
                    <i class="bi bi-person-plus-fill text-primary fs-2"></i>
                </div>
                <h2 class="fw-bold text-white mb-2">Create Account</h2>
                <p class="text-dim">Join OrbitPM to start managing your projects</p>
            </div>

            <form asp-controller="Account" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 font-monospace small"></div>
                
                <div class="mb-4">
                    <label class="form-label small text-uppercase ls-wide">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="Enter your full name" required />
                    <span asp-validation-for="FullName" class="text-danger small mt-1 d-block font-monospace"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label small text-uppercase ls-wide">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" required />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block font-monospace"></span>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-md-6">
                        <label class="form-label small text-uppercase ls-wide">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block font-monospace"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-uppercase ls-wide">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block font-monospace"></span>
                    </div>
                </div>

                <button type="submit" class="w-100 btn btn-primary mb-4 py-3">
                    Create Account <i class="bi bi-person-check-fill ms-2"></i>
                </button>

                <div class="text-center">
                    <p class="text-dim small mb-0">Already have an account? <a asp-action="Login" class="text-primary text-decoration-none fw-bold">Login here</a></p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

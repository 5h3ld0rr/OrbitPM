<ul class="navbar-nav">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <li class="nav-item d-flex align-items-center">
            <span class="text-secondary fw-bold me-3">Welcome, @(User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User")!</span>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="nav-link btn btn-link text-danger border border-danger rounded ms-2">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-white fw-bold px-3" asp-controller="Account" asp-action="Register">Register</a>
        </li>
        <li class="nav-item d-flex align-items-center">
            <a class="btn btn-primary text-dark fw-bold ms-lg-3 px-4 shadow-sm" asp-controller="Account" asp-action="Login">Login</a>
        </li>
    }
</ul>

@model OrbitPM.Models.HomeDashboardViewModel
@{
    ViewData["Title"] = Model.DashboardTitle;
}

<div class="container-fluid py-4 fade-in-up">
    <!-- Dashboard Header -->
    <div class="d-flex justify-content-between align-items-center border-bottom border-secondary border-opacity-25 pb-3 mb-4">
        <div>
            <h2 class="fw-bolder mb-0"><i class="bi bi-activity text-primary me-2 pulse-glow rounded-circle shadow-sm"></i>@Model.DashboardTitle</h2>
            <p class="text-secondary mb-0">@Model.DashboardSubtitle</p>
        </div>
        
        @if (!User.Identity?.IsAuthenticated ?? true)
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
                <i class="bi bi-shield-lock-fill me-2"></i> Access Terminal
            </a>
        }
        else
        {
            <a asp-controller="@(User.IsInRole("ModuleLeader") ? "ModuleLeaderDashboard" : User.IsInRole("Supervisor") ? "SupervisorDashboard" : "StudentDashboard")" asp-action="Index" class="btn btn-outline-light fw-bold shadow-sm rounded-pill px-4 text-secondary border-secondary">
                <i class="bi bi-box-arrow-up-right me-2"></i> Legacy Workspace
            </a>
        }
    </div>

    <!-- Metrics Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card stat-card border-0 h-100 p-4 rounded-4" style="background: linear-gradient(145deg, rgba(13,20,36,0.8) 0%, rgba(5,8,16,0.95) 100%);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted fw-bold text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">@Model.Stat1Label</span>
                    <i class="bi @Model.Stat1Icon fs-4 @Model.Stat1Color opacity-75"></i>
                </div>
                <h2 class="display-5 fw-bolder mb-0 text-white">@Model.Stat1Value</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card border-0 h-100 p-4 rounded-4" style="background: linear-gradient(145deg, rgba(13,20,36,0.8) 0%, rgba(5,8,16,0.95) 100%);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted fw-bold text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">@Model.Stat2Label</span>
                    <i class="bi @Model.Stat2Icon fs-4 @Model.Stat2Color opacity-75"></i>
                </div>
                <h2 class="display-5 fw-bolder mb-0 text-white">@Model.Stat2Value</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card border-0 h-100 p-4 rounded-4" style="background: linear-gradient(145deg, rgba(13,20,36,0.8) 0%, rgba(5,8,16,0.95) 100%); border-left: 3px solid var(--primary) !important;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted fw-bold text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">@Model.Stat3Label</span>
                    <i class="bi @Model.Stat3Icon fs-4 @Model.Stat3Color opacity-75"></i>
                </div>
                <h2 class="display-5 fw-bolder mb-0 text-white">@Model.Stat3Value</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card border-0 h-100 p-4 rounded-4" style="background: linear-gradient(145deg, rgba(13,20,36,0.8) 0%, rgba(5,8,16,0.95) 100%); border-left: 3px solid var(--accent) !important;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted fw-bold text-uppercase" style="font-size: 0.8rem; letter-spacing: 1px;">@Model.Stat4Label</span>
                    <i class="bi @Model.Stat4Icon fs-4 @Model.Stat4Color opacity-75"></i>
                </div>
                <h2 class="display-5 fw-bolder mb-0 text-white">@Model.Stat4Value</h2>
            </div>
        </div>
    </div>

    <!-- Recent Activity Table -->
    <div class="card border-0 p-4 rounded-5" style="background: rgba(13,20,36,0.4); backdrop-filter: blur(20px);">
        <h4 class="fw-bold mb-4"><i class="bi bi-list-columns-reverse me-2 text-primary"></i> @Model.TableTitle</h4>
        
        <div class="table-responsive">
            <table class="table custom-table table-hover align-middle mb-0">
                <thead class="bg-transparent text-secondary">
                    <tr>
                        <th class="border-0">Title</th>
                        <th class="border-0">Domain</th>
                        <th class="border-0 text-center">Status</th>
                        <th class="border-0 text-end">Time</th>
                    </tr>
                </thead>
                <tbody class="border-top border-secondary border-opacity-25">
                    @if (Model.ProposalsList.Any())
                    {
                        foreach (var p in Model.ProposalsList)
                        {
                            <tr>
                                <td class="fw-bold text-white py-3">
                                    <i class="bi bi-file-earmark-code text-primary me-2"></i> @p.Title
                                </td>
                                <td>
                                    <span class="badge rounded-pill bg-transparent border border-secondary text-secondary">
                                        @p.ResearchArea?.Name
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if(p.Status == OrbitPM.Models.ProjectStatus.Pending)
                                    {
                                        <span class="badge rounded-pill bg-warning text-dark px-3"><i class="bi bi-hourglass-split me-1"></i> Pending</span>
                                    }
                                    else if (p.Status == OrbitPM.Models.ProjectStatus.Matched)
                                    {
                                        <span class="badge rounded-pill bg-success text-dark px-3"><i class="bi bi-check-circle-fill me-1"></i> Matched</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary text-dark px-3">@p.Status</span>
                                    }
                                </td>
                                <td class="text-end text-muted small font-monospace">@p.CreatedAt.ToString("MMM dd HH:mm")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <i class="bi bi-hdd-network fs-1 d-block mb-3 opacity-50"></i>
                                No signals detected waiting in queue
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
